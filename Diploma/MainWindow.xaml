<Window
    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
    MinHeight="800"
    MinWidth="1024"
    Title="MainWindow"
    d:DataContext="{d:DesignInstance viewModel:MainWindowViewModel}"
    mc:Ignorable="d"
    x:Class="Diploma.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="clr-namespace:Diploma.View"
    xmlns:viewModel="clr-namespace:Diploma.ViewModel"
    xmlns:vm="clr-namespace:ImageAnalysis.Application.Dtos;assembly=ImageAnalysis.Application"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Window.Resources>
        <Style TargetType="Border" x:Key="FloatingWidgetStyle">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </Window.Resources>
    <Grid ColumnDefinitions="250,*, 250" RowDefinitions="Auto, *">
        <Border
            Grid.Column="0"
            Grid.RowSpan="2"
            Margin="12"
            Style="{StaticResource FloatingWidgetStyle}">
            <view:OperationHistoryControl DataContext="{Binding OperationHistoryViewModel}" />
        </Border>

        <Border
            Grid.Column="1"
            Grid.Row="0"
            Margin="0,12"
            Style="{StaticResource FloatingWidgetStyle}">
            <view:ProjectManagementControl DataContext="{Binding ProjectManagementViewModel}" />
        </Border>
        <Border
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Grid.Column="1"
            Grid.Row="1"
            Margin="0,0,0,12">
            <Grid>
                <view:ImageViewerControl DataContext="{Binding ImageViewerViewModel}" />
            </Grid>
        </Border>
        <Border
            Grid.Column="2"
            Grid.RowSpan="2"
            Margin="12"
            Style="{StaticResource FloatingWidgetStyle}">
            <view:FiltersControl DataContext="{Binding FiltersViewModel}" />
        </Border>
    </Grid>
</Window>