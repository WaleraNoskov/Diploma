<Window
    Height="800"
    MinHeight="600"
    MinWidth="800"
    Title="MainWindow"
    Width="800"
    d:DataContext="{d:DesignInstance viewModel:MainWindowViewModel}"
    mc:Ignorable="d"
    x:Class="Diploma.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="clr-namespace:Diploma.View"
    xmlns:viewModel="clr-namespace:Diploma.ViewModel"
    xmlns:vm="clr-namespace:ImageAnalysis.Application.Dtos;assembly=ImageAnalysis.Application"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <view:ProjectManagementControl DataContext="{Binding ProjectManagementViewModel}" Grid.Row="0" />
        <view:ImageViewerControl DataContext="{Binding ImageViewerViewModel}" Grid.Row="1" />
    </Grid>
</Window>