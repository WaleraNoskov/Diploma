<UserControl
    d:DataContext="{d:DesignInstance viewModel:ProjectManagementViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="Diploma.View.ProjectManagementControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Diploma.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:Diploma.ViewModel"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Top">
        <TextBlock
            FontSize="14"
            FontWeight="SemiBold"
            Margin="0,0,4,0"
            Text="{Binding ProjectName}"
            VerticalAlignment="Center" />
        <Button
            Command="{Binding OpenFileCommand}"
            Content="Открыть"
            Grid.Column="1"
            VerticalAlignment="Center" />
    </Grid>
</UserControl>
