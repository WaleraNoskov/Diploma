<UserControl
    d:DataContext="{d:DesignInstance viewModel:ImageViewerViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="Diploma.View.ImageViewerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:diploma="clr-namespace:Diploma.View"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Diploma.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:Diploma.ViewModel"
    xmlns:visualBasic="clr-namespace:Microsoft.VisualBasic;assembly=Microsoft.VisualBasic.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ScrollViewer
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            x:Name="PART_Scroll">

            <Grid>
                <!--  IMAGE  -->
                <Image
                    RenderTransform="{Binding Transform}"
                    RenderTransformOrigin="0,0"
                    Source="{Binding ImageSource}"
                    x:Name="TargetImage" />

                <!--  OVERLAY  -->
                <local:OverlayVisualHost
                    DataContext="{Binding}"
                    Height="{Binding ElementName=TargetImage, Path=ActualHeight}"
                    IsHitTestVisible="False"
                    RenderTransform="{Binding Transform}"
                    Width="{Binding ElementName=TargetImage, Path=ActualWidth}" />

                <!--  INPUT  -->
                <i:Interaction.Behaviors>
                    <local:ImageMouseBehavior
                        ClickCommand="{Binding ClickCommand}"
                        MouseMoveCommand="{Binding MouseMoveCommand}"
                        WheelCommand="{Binding MouseWheelCommand}" />
                </i:Interaction.Behaviors>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>