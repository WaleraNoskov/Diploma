<UserControl
    d:DataContext="{d:DesignInstance viewModel:ImageViewerViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="Diploma.View.ImageViewerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:diploma="clr-namespace:Diploma.View"
    xmlns:global="clr-namespace:"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:infrastructure="clr-namespace:Diploma.Infrastructure"
    xmlns:local="clr-namespace:Diploma.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:Diploma.ViewModel"
    xmlns:visualBasic="clr-namespace:Microsoft.VisualBasic;assembly=Microsoft.VisualBasic.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <infrastructure:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Canvas
            Height="{Binding ElementName=Image, Path=ActualHeight}"
            Width="{Binding ElementName=Image, Path=ActualWidth}"
            x:Name="Surface">

            <Canvas.LayoutTransform>
                <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
            </Canvas.LayoutTransform>

            <!--  IMAGE  -->
            <Image
                RenderTransform="{Binding Transform}"
                RenderTransformOrigin="0,0"
                Source="{Binding ImageSource}"
                x:Name="Image" />

            <!--  OVERLAY  -->
            <local:OverlayVisualHost
                Height="{Binding ElementName=Image, Path=ActualHeight}"
                IsHitTestVisible="False"
                RenderTransform="{Binding Transform}"
                Width="{Binding ElementName=Image, Path=ActualWidth}" />

            <i:Interaction.Behaviors>
                <global:ZoomPanBehavior />
            </i:Interaction.Behaviors>
        </Canvas>
    </ScrollViewer>

</UserControl>